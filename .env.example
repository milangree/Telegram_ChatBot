# 服务器端口
PORT=3000

# 数据库类型 (kv / d1 / hyperdrive)
ACTIVE_DB=kv

# KV 文件路径（SQLite 存储文件）
KV_FILE=db.sqlite

# PostgreSQL 连接字符串（Hyperdrive 模式）
DATABASE_URL=

# Cookie Secure 标志（HTTPS 反向代理时设为 true）
COOKIE_SECURE=false

# KV 持久化
KV_PERSIST=true

# 初始管理员账号（Docker/VPS 部署）
# 首次启动时使用此密码创建管理员，密码不会以明文出现在日志中
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# 管理员恢复 CLI 默认读取以下路径（可用 npm run admin -- list）
# KV_FILE=./data/kv-store.db
# D1_FILE=./data/d1-store.db
# DATABASE_URL=
